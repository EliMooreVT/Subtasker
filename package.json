{
  "name": "subtasker-root",
  "version": "0.1.0",
  "private": true,
  "description": "Subtasker — monorepo root",
  "workspaces": [
    "packages/*"
  ],
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --clearScreen false",
    "dev:main": "wait-on tcp:5173 && electron .",
    "start": "electron .",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "test": "jest",
    "go": "bash scripts/go.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
