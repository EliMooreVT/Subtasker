{
  "name": "subtasker",
  "version": "0.1.0",
  "description": "Subtasker desktop app that extends Google Tasks with AI-powered subtasks.",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --clearScreen false",
    "dev:main": "wait-on tcp:5173 && electron .",
    "start": "electron .",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "jsonrepair": "^3.13.0",
    "openai": "^4.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
